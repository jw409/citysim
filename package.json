{
  "name": "urbansynth",
  "version": "6.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e-ui": "playwright test --ui",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src/**/*.{ts,tsx}",
    "format:check": "prettier --check src/**/*.{ts,tsx}",
    "typecheck": "tsc --noEmit",
    "prebuild": "npm run build:city && npm run build:wasm",
    "build:wasm": "cd wasm && wasm-pack build --target web --out-dir ../src/wasm",
    "build:city": "node scripts/generate_city.cjs",
    "protoc": "npx pbjs -t static-module -w commonjs -o src/data/city_model.js src/data/city_model.proto && npx pbts -o src/data/city_model.d.ts src/data/city_model.js"
  },
  "dependencies": {
    "@deck.gl/core": "^9.0.0",
    "@deck.gl/layers": "^9.0.0",
    "@deck.gl/mesh-layers": "^9.1.14",
    "@deck.gl/react": "^9.0.0",
    "@loaders.gl/core": "^4.2.0",
    "@loaders.gl/gltf": "^4.2.0",
    "@loaders.gl/obj": "^4.3.4",
    "protobufjs": "^7.5.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "simplex-noise": "^4.0.3",
    "three": "^0.160.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@playwright/test": "^1.55.0",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/protobufjs": "^6.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@types/three": "^0.160.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "eslint": "^8.0.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "jsdom": "^27.0.0",
    "prettier": "^3.0.0",
    "protobufjs-cli": "^1.1.3",
    "react-hooks": "^1.0.1",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
